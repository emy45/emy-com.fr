{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|avif|svg|gif|ico|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_a/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/accompagner-les-entreprises-dans-leurs-ambitions-de-communication", "destination": "/emy", "permanent": true },
    { "source": "/mes-realisations-de-communication", "destination": "/realisations", "permanent": true },
    { "source": "/chartes-graphiques-2", "destination": "/chartes-graphiques", "permanent": true },
    { "source": "/campagnes-daffichage", "destination": "/campagnes-affichage", "permanent": true },
    { "source": "/plaquettes-commerciales", "destination": "/plaquettes", "permanent": true },
    { "source": "/kit-de-communication-entrepreneur", "destination": "/kit-entrepreneur", "permanent": true },
    { "source": "/objets-publicitaires-2", "destination": "/objets-publicitaires", "permanent": true },
    { "source": "/agence-de-communication-a-orleans", "destination": "/contact", "permanent": true }
  ]
}
