---
interface Props {
  title?: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { title, text, ctaLabel, ctaHref } = Astro.props;

// French typography: prevent line breaks before ? ! : ; » by replacing regular spaces with NBSP
const frTypo = (s?: string) => s?.replace(/ ([?!:;»])/g, " $1");
---

<aside class="bg-[color:var(--color-brand)] text-white">
  <div class="container-x py-12 md:py-16 flex flex-col items-center justify-center text-center gap-6">
    <div class="max-w-2xl">
      {title && (
        <p class="title-section !text-white">{frTypo(title)}</p>
      )}
      {text && (
        <p class="mt-3 text-white/90 text-base md:text-lg leading-relaxed">{frTypo(text)}</p>
      )}
    </div>
    {ctaLabel && ctaHref && (
      <a
        href={ctaHref}
        class="inline-block bg-white text-[color:var(--color-brand)] font-semibold uppercase tracking-[0.08em] text-sm px-7 py-3.5 rounded-full hover:bg-white/90 transition-colors"
        style="font-family:var(--font-display)"
      >
        {ctaLabel}
      </a>
    )}
  </div>
</aside>
