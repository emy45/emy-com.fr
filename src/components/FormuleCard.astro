---
import Picture from "@/components/Picture.astro";
interface Props {
  icon: string;
  title: string;
  text: string;
}
const { icon, title, text } = Astro.props;
---

<article class="flex flex-col items-center text-center px-2 py-6">
  <Picture
    src={icon}
    alt=""
    width={180}
    height={180}
    class="h-32 w-auto mb-5"
  />
  <h3 class="title-section !text-2xl mb-3">{title}</h3>
  <p class="text-[color:var(--color-ink-muted)] leading-relaxed max-w-md">{text}</p>
</article>
