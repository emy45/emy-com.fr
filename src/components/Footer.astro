---
import { site } from "@/data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-line)] bg-white">
  <div class="container-x py-10 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[color:var(--color-ink-muted)]">
      <span>Emy &nbsp;—&nbsp; © {year}</span>
      <span class="hidden sm:inline opacity-70">L'Émy'sphère, depuis 2015</span>
      <a href="/mentions-legales" class="hover:text-[color:var(--color-brand)] underline-offset-4 hover:underline">
        Mentions légales
      </a>
      <a href="#tarteaucitron" class="hover:text-[color:var(--color-brand)] underline-offset-4 hover:underline cursor-pointer">
        Gérer les cookies
      </a>
    </div>

    <div class="flex items-center gap-3">
      <a
        href={site.social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook Emy Communication"
        class="w-10 h-10 inline-flex items-center justify-center rounded-full border border-[color:var(--color-line)] hover:bg-[color:var(--color-brand)] hover:border-[color:var(--color-brand)] hover:text-white transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.7-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7A10 10 0 0 0 22 12Z"/>
        </svg>
      </a>
      <a
        href={site.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram Emy Communication"
        class="w-10 h-10 inline-flex items-center justify-center rounded-full border border-[color:var(--color-line)] hover:bg-[color:var(--color-brand)] hover:border-[color:var(--color-brand)] hover:text-white transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"></circle>
        </svg>
      </a>
      <a
        href={site.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn Émilie Richard"
        class="w-10 h-10 inline-flex items-center justify-center rounded-full border border-[color:var(--color-line)] hover:bg-[color:var(--color-brand)] hover:border-[color:var(--color-brand)] hover:text-white transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.56v-5.56c0-1.32-.03-3.03-1.85-3.03-1.85 0-2.13 1.44-2.13 2.94v5.65H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.27 2.38 4.27 5.47v6.27zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>
