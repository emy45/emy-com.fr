---
interface Props {
  title?: string;
  intro?: string;
}
const {
  title = "Vous avez un projet de communication ?",
  intro = "Contactez-moi via ce formulaire, je vous recontacterai dans les meilleurs délais.",
} = Astro.props;

const a = Math.floor(Math.random() * 9) + 1;
const b = Math.floor(Math.random() * 9) + 1;
const sum = a + b;
---

<section class="section-y bg-[color:var(--color-line-soft)]" id="contact">
  <div class="container-narrow">
    <header class="text-center mb-10">
      <h2 class="title-section">{title}</h2>
      <p class="mt-3 text-[color:var(--color-ink-muted)]">{intro}</p>
    </header>

    <form
      action="/api/contact"
      method="POST"
      class="bg-white p-6 md:p-10 border border-[color:var(--color-line)] grid gap-4"
      data-contact-form
    >
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="sr-only">Nom</span>
          <input
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder="Nom *"
            class="w-full px-4 py-3 border border-[color:var(--color-line)] focus:border-[color:var(--color-brand)] outline-none transition-colors bg-white"
          />
        </label>
        <label class="block">
          <span class="sr-only">Email</span>
          <input
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="Email *"
            class="w-full px-4 py-3 border border-[color:var(--color-line)] focus:border-[color:var(--color-brand)] outline-none transition-colors bg-white"
          />
        </label>
      </div>

      <label class="block">
        <span class="sr-only">Entreprise</span>
        <input
          name="company"
          type="text"
          autocomplete="organization"
          placeholder="Entreprise"
          class="w-full px-4 py-3 border border-[color:var(--color-line)] focus:border-[color:var(--color-brand)] outline-none transition-colors bg-white"
        />
      </label>

      <label class="block">
        <span class="sr-only">Votre message</span>
        <textarea
          name="message"
          required
          rows="6"
          placeholder="Votre message *"
          class="w-full px-4 py-3 border border-[color:var(--color-line)] focus:border-[color:var(--color-brand)] outline-none transition-colors bg-white resize-y"
        ></textarea>
      </label>

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <label class="block">
          <span class="text-sm text-[color:var(--color-ink-muted)] block mb-2">
            Vérification : <strong>{a} + {b} = ?</strong>
          </span>
          <input
            name="captcha"
            type="text"
            required
            inputmode="numeric"
            pattern="[0-9]+"
            class="w-24 px-3 py-2 border border-[color:var(--color-line)] focus:border-[color:var(--color-brand)] outline-none transition-colors bg-white"
          />
          <input type="hidden" name="captcha_expected" value={sum} />
        </label>

        {/* Honeypot anti-spam */}
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
        />

        <button
          type="submit"
          class="btn-primary hover:bg-[color:var(--color-brand-dark)]"
        >
          Envoyer
        </button>
      </div>

      <p role="status" aria-live="polite" data-form-status class="hidden text-sm mt-2"></p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = document.querySelector<HTMLParagraphElement>("[data-form-status]");
  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const expected = Number(fd.get("captcha_expected"));
      const given = Number(fd.get("captcha"));
      if (Number.isNaN(given) || given !== expected) {
        status.textContent = "La vérification est incorrecte. Merci de recalculer.";
        status.className = "text-sm mt-2 text-red-600";
        return;
      }
      if (String(fd.get("website") || "").length > 0) {
        // honeypot rempli => silencieux
        status.textContent = "Merci, votre message a bien été envoyé.";
        status.className = "text-sm mt-2 text-[color:var(--color-brand)]";
        form.reset();
        return;
      }
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: fd,
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          status.textContent = "Merci, votre message a bien été envoyé.";
          status.className = "text-sm mt-2 text-[color:var(--color-brand)]";
          form.reset();
        } else {
          status.textContent = "Une erreur est survenue. Vous pouvez aussi écrire directement à emy@emy-com.fr.";
          status.className = "text-sm mt-2 text-red-600";
        }
      } catch {
        status.textContent = "Connexion impossible. Écrivez à emy@emy-com.fr.";
        status.className = "text-sm mt-2 text-red-600";
      }
    });
  }
</script>
