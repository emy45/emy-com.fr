---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryGrid from "@/components/CategoryGrid.astro";
import ContactForm from "@/components/ContactForm.astro";
---

<BaseLayout
  title="Mes réalisations print & web"
  description="Portfolio Emy Communication : chartes graphiques, affichage, plaquettes, sites web, signalétique, édition. Projets sur-mesure à Orléans."
>
  <section class="relative overflow-hidden bg-[#222831] text-white">
    <!-- Decorative sphere graphic + circles -->
    <img
      src="/images/emy_sphere_site.webp"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      class="pointer-events-none absolute -right-32 -top-20 w-[28rem] md:w-[34rem] opacity-25 object-contain select-none"
    />
    <span aria-hidden="true" class="pointer-events-none absolute -left-24 bottom-[-6rem] w-64 h-64 rounded-full bg-white/8"></span>
    <span aria-hidden="true" class="pointer-events-none absolute left-[18%] top-6 w-10 h-10 rounded-full bg-white/5"></span>

    <div class="container-x py-20 md:py-24 text-center relative">
      <h1 class="font-display uppercase tracking-[0.04em] text-3xl md:text-5xl font-extrabold text-[color:var(--color-brand)]" style="font-family:var(--font-display)">
        Quelques réalisations
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-white/80 text-lg leading-relaxed">
        Découvrez quelques-unes de mes réalisations Print et Web dans différents domaines
        d'activité.
      </p>
    </div>
    <div class="container-x pb-24">
      <CategoryGrid />
    </div>
  </section>

  <ContactForm
    title="Vous avez un projet ?"
    intro="Contactez-moi via ce formulaire, je vous répondrai sans délai pour étudier votre projet."
  />
</BaseLayout>
