---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import CategoryGrid from "@/components/CategoryGrid.astro";
import ContactForm from "@/components/ContactForm.astro";
import TealBand from "@/components/TealBand.astro";
import { site } from "@/data/site";

const stats = [
  { value: "2015", label: "Année de création" },
  { value: "10 ans", label: "D'accompagnement" },
  { value: "Print & Web", label: "Double expertise" },
  { value: "Orléans", label: "Centre-Val de Loire & IDF" },
];

---

<BaseLayout
  title="À propos — Émilie Richard, agence à Orléans"
  description="Découvrez Émilie Richard et Emy Communication : parcours, vision et démarche d'une agence à taille humaine à Orléans."
>
  <!-- HERO sombre/teal -->
  <section class="relative overflow-hidden bg-[#222831] text-white">
    <!-- Decorative sphere graphic + circles -->
    <img
      src="/images/emy_sphere_site.webp"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      class="pointer-events-none absolute -right-32 -top-20 w-[28rem] md:w-[34rem] opacity-25 object-contain select-none"
    />
    <span aria-hidden="true" class="pointer-events-none absolute -left-24 bottom-[-6rem] w-64 h-64 rounded-full bg-white/8"></span>
    <span aria-hidden="true" class="pointer-events-none absolute left-[18%] top-6 w-10 h-10 rounded-full bg-white/5"></span>

    <div class="container-x py-16 md:py-20 text-center relative">
      <p class="font-display uppercase tracking-[0.12em] text-xs md:text-sm font-semibold text-white/70" style="font-family:var(--font-display)">
        À propos
      </p>
      <h1 class="font-display uppercase tracking-[0.04em] mt-4 text-3xl md:text-5xl font-extrabold text-[color:var(--color-brand)] max-w-3xl mx-auto leading-tight" style="font-family:var(--font-display)">
        Accompagner les entreprises dans leurs ambitions de communication
      </h1>
    </div>
  </section>

  <!-- INTRO (centré) -->
  <section class="container-x py-16 md:py-20">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="title-section !text-2xl md:!text-3xl text-[color:var(--color-ink)] mb-5">
        Une agence de communication à taille humaine, à Orléans
      </h2>
      <p class="text-[color:var(--color-ink-muted)] leading-relaxed text-lg">
        Émilie Richard fonde <strong>Emy Communication</strong> en 2015, à Orléans —
        <em>l'Émy'sphère</em>, un univers où chaque projet de communication trouve son orbite.
        L'agence accompagne depuis dix ans dirigeantes et dirigeants d'entreprises en
        Centre-Val de Loire et en Île-de-France sur leurs enjeux de communication
        <strong>print, web et événementiel</strong> — du conseil stratégique à la création
        graphique, jusqu'au suivi de fabrication.
      </p>
      <a
        href={site.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 mt-8 px-5 py-2.5 rounded-full bg-[#0a66c2] text-white text-sm font-semibold hover:bg-[#0851a0] transition-colors"
        style="font-family:var(--font-display)"
        aria-label="Profil LinkedIn d'Émilie Richard (nouvel onglet)"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.56v-5.56c0-1.32-.03-3.03-1.85-3.03-1.85 0-2.13 1.44-2.13 2.94v5.65H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.27 2.38 4.27 5.47v6.27zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
        </svg>
        Suivre Emy sur LinkedIn
      </a>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-[color:var(--color-line-soft)] py-10 md:py-12">
    <div class="container-x max-w-5xl">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-4 text-center">
        {stats.map((s) => (
          <li>
            <p class="font-display text-2xl md:text-3xl font-extrabold text-[color:var(--color-brand)]" style="font-family:var(--font-display)">
              {s.value}
            </p>
            <p class="mt-1 text-xs md:text-sm uppercase tracking-[0.06em] text-[color:var(--color-ink-muted)]" style="font-family:var(--font-display)">
              {s.label}
            </p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- MON PARCOURS -->
  <section class="container-x py-16 md:py-20">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 max-w-6xl mx-auto">
      <div class="lg:col-span-4">
        <h2 class="title-section !text-2xl md:!text-3xl text-[color:var(--color-ink)] leading-tight">
          Mon parcours — de la communication d'entreprise au digital
        </h2>
      </div>
      <div class="lg:col-span-8 space-y-5 text-[color:var(--color-ink-muted)] leading-relaxed text-lg">
        <p>
          Diplômée d'un Master 2 en Communication d'Entreprise, j'ai exercé plusieurs années en interne,
          chez l'annonceur, au contact direct des problématiques opérationnelles : campagnes
          commerciales, communication interne, recrutement, lancements produits…
          Cette expérience terrain m'a appris à <strong>écouter avant de proposer</strong>,
          et à structurer chaque projet autour d'un objectif business clair.
        </p>
        <p>
          Au fil des années, je me suis spécialisée dans le graphisme — logotypes,
          chartes graphiques, supports print et signalétique — puis dans le digital, avec
          la conception de sites vitrines responsive et l'optimisation SEO. Cette
          <strong>double culture</strong> me permet de penser un projet de communication
          de bout en bout, des fondamentaux stratégiques jusqu'aux livrables fabriqués.
        </p>
      </div>
    </div>
  </section>

  <!-- MA MÉTHODE -->
  <section class="bg-[color:var(--color-line-soft)] py-16 md:py-20">
    <div class="container-x max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">
        <div class="lg:col-span-4">
          <h2 class="title-section !text-2xl md:!text-3xl text-[color:var(--color-ink)] leading-tight">
            Ma méthode — l'écoute avant la création
          </h2>
          <p class="mt-4 text-[color:var(--color-ink-muted)] leading-relaxed">
            Chaque mission démarre par un temps d'échange, en présentiel ou en visio,
            pour comprendre votre univers, votre marché et vos contraintes. Je conçois
            ensuite des supports sur-mesure, en cohérence avec votre identité et vos
            objectifs — <strong>jamais en bibliothèque de templates</strong>.
          </p>
        </div>
        <div class="lg:col-span-8 grid sm:grid-cols-2 gap-5">
          <div class="bg-white rounded-2xl p-7 border border-[color:var(--color-line)]">
            <p class="title-eyebrow">Formule</p>
            <h3 class="font-display uppercase tracking-[0.04em] text-xl font-bold mt-2 mb-3" style="font-family:var(--font-display)">
              Au projet
            </h3>
            <p class="text-[color:var(--color-ink-muted)] leading-relaxed text-sm">
              Une mission ponctuelle avec un brief précis : refonte d'identité, plaquette
              commerciale, site vitrine, campagne d'affichage… Devis fixe, livraison cadrée.
            </p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-[color:var(--color-line)]">
            <p class="title-eyebrow">Formule</p>
            <h3 class="font-display uppercase tracking-[0.04em] text-xl font-bold mt-2 mb-3" style="font-family:var(--font-display)">
              En régie
            </h3>
            <p class="text-[color:var(--color-ink-muted)] leading-relaxed text-sm">
              Une présence régulière sur plusieurs mois, en immersion dans l'équipe : pilotage
              de la communication, production récurrente, accompagnement transverse.
            </p>
          </div>
          <div class="sm:col-span-2 bg-[color:var(--color-brand-light)] rounded-2xl p-5 text-center">
            <p class="text-[color:var(--color-brand-dark)] text-sm md:text-base">
              Dans les deux cas, vous gardez <strong>une interlocutrice unique</strong>,
              du premier rendez-vous à la livraison finale.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRANSMETTRE -->
  <section class="container-x py-16 md:py-20">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 max-w-6xl mx-auto">
      <div class="lg:col-span-4">
        <h2 class="title-section !text-2xl md:!text-3xl text-[color:var(--color-ink)] leading-tight">
          Transmettre — la formation comme moteur de veille
        </h2>
      </div>
      <div class="lg:col-span-8 text-[color:var(--color-ink-muted)] leading-relaxed text-lg">
        <p>
          Depuis plusieurs années, j'interviens auprès d'<strong>étudiants en communication
          en apprentissage</strong> : gestion de projet, méthodologie, maîtrise des
          logiciels <em>Photoshop, Illustrator</em> et <em>InDesign</em>. Transmettre
          nécessite de rester à jour sur les outils, les tendances et les nouveaux usages —
          un investissement qui profite directement à mes clients.
        </p>
      </div>
    </div>
  </section>

  <!-- VALEURS — 4 cards colorées -->
  <section class="bg-[color:var(--color-line-soft)] py-16 md:py-20">
    <div class="container-x max-w-6xl">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="title-section !text-2xl md:!text-3xl text-[color:var(--color-ink)]">
          Mes valeurs
        </h2>
        <p class="mt-4 text-[color:var(--color-ink-muted)] leading-relaxed">
          Une relation de confiance qui se construit dans la durée — voilà ce qui m'anime
          depuis 2015.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
        <!-- Sensibilité -->
        <article class="group relative block rounded-2xl p-7 text-white bg-[color:var(--color-brand)] hover:bg-[color:var(--color-brand-dark)] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
          <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/10 group-hover:scale-125 transition-transform duration-500"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-2xl bg-white/15 flex items-center justify-center mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold leading-tight text-white" style="font-family:var(--font-display)">Sensibilité</h3>
            <p class="mt-3 text-base text-white/90 leading-relaxed">
              Comprendre votre univers avant de proposer.
            </p>
          </div>
        </article>

        <!-- Créativité -->
        <article class="group relative block rounded-2xl p-7 text-white bg-[#e91e63] hover:bg-[#c2185b] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
          <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/10 group-hover:scale-125 transition-transform duration-500"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-2xl bg-white/15 flex items-center justify-center mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v3M5.6 5.6l2.1 2.1M3 12h3M5.6 18.4l2.1-2.1M12 21v-3M18.4 18.4l-2.1-2.1M21 12h-3M18.4 5.6l-2.1 2.1"></path>
                <circle cx="12" cy="12" r="3.5"></circle>
              </svg>
            </div>
            <h3 class="text-xl font-bold leading-tight text-white" style="font-family:var(--font-display)">Créativité</h3>
            <p class="mt-3 text-base text-white/90 leading-relaxed">
              Des solutions sur-mesure, pas de templates existants.
            </p>
          </div>
        </article>

        <!-- Réactivité -->
        <article class="group relative block rounded-2xl p-7 text-white bg-[#f5b800] hover:bg-[#d99e00] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
          <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/15 group-hover:scale-125 transition-transform duration-500"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
            </div>
            <h3 class="text-xl font-bold leading-tight text-white" style="font-family:var(--font-display)">Réactivité</h3>
            <p class="mt-3 text-base text-white/95 leading-relaxed">
              Réponse dans 48 h, suivi sans intermédiaire.
            </p>
          </div>
        </article>

        <!-- Détermination -->
        <article class="group relative block rounded-2xl p-7 text-white bg-[#222831] hover:bg-[#1a1f26] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
          <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/10 group-hover:scale-125 transition-transform duration-500"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-2xl bg-white/15 flex items-center justify-center mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="6"></circle>
                <circle cx="12" cy="12" r="2"></circle>
              </svg>
            </div>
            <h3 class="text-xl font-bold leading-tight text-white" style="font-family:var(--font-display)">Détermination</h3>
            <p class="mt-3 text-base text-white/90 leading-relaxed">
              Engagements tenus, du brief à la livraison.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <TealBand
    title="Un projet de communication ?"
    text="Échangeons ensemble sur vos enjeux et trouvons la formule qui vous correspond."
    ctaLabel="Me contacter"
    ctaHref="/contact"
  />

  <Section
    eyebrow="Quelques réalisations"
    title="Print & web en action"
    intro="Découvrez quelques-unes de mes réalisations Print et Web dans différents domaines d'activité."
  >
    <CategoryGrid />
  </Section>

  <ContactForm />
</BaseLayout>
