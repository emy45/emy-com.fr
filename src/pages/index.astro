---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import FormuleCard from "@/components/FormuleCard.astro";
import ContactForm from "@/components/ContactForm.astro";
import { site } from "@/data/site";

const serviceCatalog = [
  {
    name: "Conseil stratégique en communication",
    description:
      "Accompagnement stratégique dans vos démarches de communication institutionnelle, commerciale & interne.",
    serviceType: "Conseil en communication",
  },
  {
    name: "Création graphique print & web",
    description:
      "Conception graphique et suivi de fabrication de l'ensemble de vos supports de communication print & web : logotype, charte graphique, plaquette, site web, signalétique.",
    serviceType: "Direction artistique et création graphique",
  },
  {
    name: "Formation PAO et chaîne graphique",
    description:
      "Initiation et perfectionnement Photoshop, Illustrator, InDesign. Chaîne graphique et stratégie de communication.",
    serviceType: "Formation professionnelle",
  },
];

const prestations = [
  {
    icon: "/images/conseil-1.png",
    iconAlt: "Accompagnement stratégique",
    text: "Accompagnement stratégique dans vos démarches de communication institutionnelle, commerciale & interne.",
  },
  {
    icon: "/images/creation-1.png",
    iconAlt: "Création de supports",
    text: "Conception graphique et suivi de fabrication de l'ensemble de vos supports de communication print & web.",
  },
  {
    icon: "/images/formation-1.png",
    iconAlt: "Formation PAO",
    text: "Chaîne graphique — Initiation et perfectionnement sur les logiciels Photoshop, Illustrator, InDesign — Stratégie de communication.",
  },
];

const services = [
  {
    icon: "/images/picto_strategie.png",
    iconAlt: "Conseil stratégique en communication — Emy à Orléans",
    title: "Conseil stratégique",
    text: "Études — Positionnements — Axes stratégiques — Plans de communication",
  },
  {
    icon: "/images/picto_identite_visuelle.png",
    iconAlt: "Création d'identité visuelle et de logotypes",
    title: "Identité visuelle",
    text: "Logotypes — Chartes graphiques — Kits de communication entrepreneur",
  },
  {
    icon: "/images/picto_site_internet.png",
    iconAlt: "Création de sites web vitrine et optimisation SEO",
    title: "Création de sites",
    text: "Sites web vitrine — Optimisation SEO — Stratégie SEA — Rédaction",
  },
  {
    icon: "/images/picto_signaletique.png",
    iconAlt: "Création de signalétique intérieure et extérieure",
    title: "Signalétique",
    text: "Création de signalétiques intérieures et extérieures",
  },
  {
    icon: "/images/picto_edition.png",
    iconAlt: "Édition print, journaux internes, rapports annuels et publicité",
    title: "Édition & publicité",
    text: "Journaux internes — Notes d'information — Rapports annuels — Catalogues — Annonces presse — Affichage",
  },
  {
    icon: "/images/picto_evenementiel.png",
    iconAlt: "Organisation d'événements internes et externes",
    title: "Événementiel",
    text: "Organisation d'événements internes et externes (anniversaires d'entreprise — marketing — salons)",
  },
];
---

<BaseLayout
  title="Agence de communication cré'active à Orléans"
  description="Agence à taille humaine à Orléans : stratégie, identité visuelle, print & web. Accompagnement global en Centre-Val de Loire & IDF depuis 2015."
  preloadImage="/images/emy_sphere.webp"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": serviceCatalog.map((s) => ({
        "@type": "Service",
        name: s.name,
        description: s.description,
        serviceType: s.serviceType,
        provider: { "@id": `${site.url}/#organization` },
        areaServed: [
          { "@type": "AdministrativeArea", name: "Centre-Val de Loire" },
          { "@type": "AdministrativeArea", name: "Île-de-France" },
        ],
      })),
    })}
  />
  <!-- HERO -->
  <section class="relative grid grid-cols-1 md:grid-cols-2">
    <!-- Left: teal panel with title and CTAs -->
    <div class="relative overflow-hidden bg-[color:var(--color-brand)] text-white flex items-center min-h-[70vh] md:min-h-[640px]">
      <div class="relative w-full px-8 py-20 md:px-12 lg:px-20 md:py-24">
        <p class="font-display uppercase tracking-[0.18em] text-xs md:text-sm font-semibold text-white/90" style="font-family:var(--font-display)">
          Emy Communication
        </p>
        <h1 class="mt-6 font-display uppercase tracking-[0.04em] leading-[0.95] text-5xl md:text-6xl lg:text-7xl font-extrabold" style="font-family:var(--font-display)">
          Agence <br />Cré'active
        </h1>
        <p class="mt-8 max-w-md text-white/90 text-lg leading-relaxed">
          Une démarche humaine &amp; créative en interaction avec un monde qui évolue.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/emy"
            class="inline-block px-7 py-[0.95rem] text-sm font-semibold uppercase tracking-[0.12em] border-2 border-white text-white rounded-full hover:bg-white hover:text-[color:var(--color-brand)] transition-colors"
            style="font-family:var(--font-display)"
          >
            En savoir plus
          </a>
          <a
            href="/realisations"
            class="inline-block px-7 py-[0.95rem] text-sm font-semibold uppercase tracking-[0.12em] bg-white text-[color:var(--color-brand)] rounded-full hover:bg-white/90 transition-colors"
            style="font-family:var(--font-display)"
          >
            Mes réalisations
          </a>
        </div>
      </div>
    </div>

    <!-- Right: dark panel with sphere visual -->
    <div
      class="relative bg-[#222831] flex items-center justify-center overflow-hidden min-h-[420px] md:min-h-[640px]"
    >
      <img
        src="/images/emy_sphere.webp"
        alt="Emy — conseil en communication"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1600"
        height="1100"
        class="absolute inset-0 h-full w-full object-cover object-center"
      />
    </div>
  </section>

  <!-- PRESTATIONS -->
  <Section
    eyebrow="Prestations"
    title="Une démarche cré'active"
    intro="Une petite agence qui a de grandes ambitions pour ses clients. Emy propose un accompagnement global en Centre-Val de Loire & Île-de-France depuis 2015."
  >
    <div class="grid md:grid-cols-3 gap-5 md:gap-6 max-w-5xl mx-auto mt-4">
      <!-- Conseil -->
      <article class="group relative block rounded-2xl p-8 text-white bg-[color:var(--color-brand)] hover:bg-[color:var(--color-brand-dark)] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
        <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/10 group-hover:scale-125 transition-transform duration-500"></div>
        <div class="relative">
          <div class="w-14 h-14 rounded-2xl bg-white/15 flex items-center justify-center mb-5">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 18h6"></path>
              <path d="M10 22h4"></path>
              <path d="M12 2a7 7 0 0 0-4 12.7c.7.7 1 1.6 1 2.6V18h6v-.7c0-1 .3-1.9 1-2.6A7 7 0 0 0 12 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold leading-tight" style="font-family:var(--font-display)">Conseil</h3>
          <p class="mt-3 text-sm text-white/90 leading-relaxed">
            Accompagnement stratégique dans vos démarches de communication institutionnelle, commerciale &amp; interne.
          </p>
        </div>
      </article>

      <!-- Création -->
      <article class="group relative block rounded-2xl p-8 text-white bg-[#e91e63] hover:bg-[#c2185b] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
        <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/10 group-hover:scale-125 transition-transform duration-500"></div>
        <div class="relative">
          <div class="w-14 h-14 rounded-2xl bg-white/15 flex items-center justify-center mb-5">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m15 4 5 5-11 11H4v-5z"></path>
              <path d="m13 6 5 5"></path>
              <path d="m20 4 1 1"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold leading-tight" style="font-family:var(--font-display)">Création</h3>
          <p class="mt-3 text-sm text-white/90 leading-relaxed">
            Conception graphique et suivi de fabrication de l'ensemble de vos supports de communication print &amp; web.
          </p>
        </div>
      </article>

      <!-- Formation -->
      <article class="group relative block rounded-2xl p-8 text-white bg-[#f5b800] hover:bg-[#d99e00] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl overflow-hidden">
        <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/15 group-hover:scale-125 transition-transform duration-500"></div>
        <div class="relative">
          <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center mb-5">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 10 12 4 2 10l10 6 10-6z"></path>
              <path d="M6 12v5c0 1 3 3 6 3s6-2 6-3v-5"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold leading-tight" style="font-family:var(--font-display)">Formation</h3>
          <p class="mt-3 text-sm text-white/95 leading-relaxed">
            Chaîne graphique — Initiation et perfectionnement sur les logiciels Photoshop, Illustrator, InDesign — Stratégie de communication.
          </p>
        </div>
      </article>
    </div>
  </Section>

  <!-- SERVICES -->
  <Section
    bg="soft"
    eyebrow="Services"
    title="Une palette sur-mesure"
    intro="Une palette de services sur-mesure pour répondre à l'ensemble de vos problématiques de communication."
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-y-12 gap-x-6">
      {services.map((s) => <ServiceCard {...s} />)}
    </div>
  </Section>

  <!-- SOLUTIONS D'ACCOMPAGNEMENT -->
  <Section
    eyebrow="Solutions d'accompagnement"
    title="Au projet ou en régie"
    intro="En fonction du besoin de communication, deux formules d'accompagnement sont possibles. Dans les deux cas, cela commence toujours par un premier rendez-vous (physique ou visio), en fonction de vos disponibilités."
  >
    <div class="grid md:grid-cols-2 gap-8 mt-4">
      <FormuleCard
        icon="/images/forfait.png"
        iconAlt="Accompagnement au projet — formule forfait"
        title="Au projet"
        text="Vous avez un projet de communication précis et vous souhaitez être accompagné ponctuellement sur la mise en place d'une opération ou sur la création d'un ou plusieurs supports de communication."
      />
      <FormuleCard
        icon="/images/regie.png"
        iconAlt="Accompagnement long terme en régie"
        title="En régie"
        text="Vous avez besoin d'un accompagnement sur le long terme pour élaborer une stratégie de communication et la mettre en place sur plusieurs mois, avec une présence sur place possible en fonction des étapes."
      />
    </div>
  </Section>

  <ContactForm />
</BaseLayout>
